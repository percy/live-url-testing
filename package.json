{
  "private": true,
  "name": "percy-live-url-test",
  "version": "1.0.0",
  "description": "Percy live URL visual regression tests for browser-upgrade validation. Run via Buildkite pipeline percy/live-url-test.",
  "scripts": {
    "test-web": "percy exec -- playwright test tests/percy_web.spec.js --reporter=dot",
    "test-web:js-enabled": "cp .percy.js-enabled.yml .percy.yml && npm run test-web",
    "test-web:js-disabled": "cp .percy.js-disabled.yml .percy.yml && npm run test-web",
    "cycle:create-projects": "node bin/create-projects.js",
    "cycle:fetch-diffs": "node bin/fetch-diffs.js",
    "cycle:report": "node bin/collect-cycle-report.js",
    "encrypt:config": "node bin/encrypt-config.js",
    "decrypt:config": "node bin/decrypt-config.js"
  },
  "devDependencies": {
    "@percy/cli": "^1.30.7",
    "@percy/playwright": "^1.0.9",
    "@playwright/test": "^1.48.0"
  },
  "engines": {
    "node": ">=20"
  }
}
